<% layout('layouts/main') %>

<div class="mb-4">
  <a href="/customer/shop" class="text-primary hover:underline text-sm"><i class="fas fa-arrow-left mr-1"></i>Back to Shop</a>
</div>

<div class="bg-white rounded-2xl shadow-lg overflow-hidden">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
    <!-- Product Image -->
    <div class="relative">
      <img src="<%= product.imageUrl %>" alt="<%= product.name %>" class="w-full h-80 md:h-full object-cover" />
      <span class="absolute top-4 left-4 bg-primary/90 text-white text-sm px-4 py-1 rounded-full capitalize"><%= product.category %></span>
    </div>

    <!-- Product Details & Order Form -->
    <div class="p-6 md:p-8">
      <h1 class="text-3xl font-bold text-dark"><%= product.name %></h1>
      <p class="text-gray-500 mt-2 leading-relaxed"><%= product.description %></p>

      <div class="flex items-center gap-4 mt-4">
        <span class="text-primary font-bold text-3xl">&#8369;<%= product.basePrice.toFixed(2) %></span>
        <span class="text-sm text-gray-400">
          <i class="fas fa-box mr-1"></i><%= product.stock %> in stock
        </span>
      </div>

      <% if (product.status === 'available' && product.stock > 0) { %>
        <form action="/customer/cart/add" method="POST" enctype="multipart/form-data" class="mt-6 space-y-4">
          <input type="hidden" name="productId" value="<%= product._id %>" />

          <!-- Size Selection -->
          <% if (product.sizes && product.sizes.length > 0) { %>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Select Size</label>
              <div class="flex flex-wrap gap-2">
                <% product.sizes.forEach((size, i) => { %>
                  <label class="cursor-pointer">
                    <input type="radio" name="selectedSize" value="<%= size %>" class="hidden peer" <%= i === 0 ? 'checked' : '' %> />
                    <span class="inline-block px-4 py-2 border-2 border-gray-200 rounded-lg text-sm font-medium peer-checked:border-primary peer-checked:bg-primary/10 peer-checked:text-primary transition">
                      <%= size %>
                    </span>
                  </label>
                <% }) %>
              </div>
            </div>
          <% } %>

          <!-- Color Selection -->
          <% if (product.colors && product.colors.length > 0) { %>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-2">Select Color</label>
              <div class="flex flex-wrap gap-2">
                <% product.colors.forEach((color, i) => { %>
                  <label class="cursor-pointer">
                    <input type="radio" name="selectedColor" value="<%= color %>" class="hidden peer" <%= i === 0 ? 'checked' : '' %> />
                    <span class="inline-block px-4 py-2 border-2 border-gray-200 rounded-lg text-sm font-medium peer-checked:border-primary peer-checked:bg-primary/10 peer-checked:text-primary transition capitalize">
                      <%= color %>
                    </span>
                  </label>
                <% }) %>
              </div>
            </div>
          <% } %>

          <!-- Custom Text -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              <i class="fas fa-font mr-1"></i>Custom Text <span class="text-gray-400">(optional)</span>
            </label>
            <input type="text" name="customText" maxlength="100" placeholder="e.g. Happy Birthday, Maria!"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition" />
          </div>

          <!-- Upload Inspo / Custom Image -->
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">
              <i class="fas fa-image mr-1"></i>Upload Inspo / Design <span class="text-gray-400">(optional)</span>
            </label>
            <div class="border-2 border-dashed border-gray-300 rounded-lg p-6 text-center hover:border-primary transition cursor-pointer" id="dropzone">
              <input type="file" name="customImage" accept="image/*" class="hidden" id="customImageInput" onchange="previewImage(this)" />
              <div id="upload-placeholder">
                <i class="fas fa-cloud-upload-alt text-gray-400 text-3xl mb-2"></i>
                <p class="text-gray-500 text-sm">Click to upload or drag your inspo photo here</p>
                <p class="text-gray-400 text-xs mt-1">JPG, PNG, SVG up to 500MB</p>
              </div>
              <div id="upload-preview" class="hidden">
                <img id="preview-img" class="max-h-40 mx-auto rounded-lg" />
                <button type="button" onclick="clearImage()" class="mt-2 text-red-500 text-sm hover:underline">
                  <i class="fas fa-trash mr-1"></i>Remove
                </button>
              </div>
            </div>
          </div>

          <!-- Quantity -->
          <div class="flex items-center gap-2">
  <button type="button" id="minus-btn" class="w-10 h-10 border border-gray-300 rounded-lg flex items-center justify-center hover:bg-gray-100 transition">
    <i class="fas fa-minus"></i>
  </button>
  
  <input type="number" name="quantity" id="qty" value="1" min="1" max="<%= product.stock %>"
    class="w-20 text-center px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary outline-none" />
  
  <button type="button" id="plus-btn" class="w-10 h-10 border border-gray-300 rounded-lg flex items-center justify-center hover:bg-gray-100 transition">
    <i class="fas fa-plus"></i>
  </button>
</div>

          <button type="submit" class="w-full bg-blue-500 hover:bg-blue-700 text-white font-bold py-3 rounded-xl transition text-lg">
            <i class="fas fa-cart-plus mr-2"></i>Add to Cart
          </button>
        </form>
      <% } else { %>
        <div class="mt-6 bg-red-50 text-red-600 px-4 py-3 rounded-lg text-center font-semibold">
          <i class="fas fa-exclamation-triangle mr-2"></i>This product is currently unavailable.
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const qtyInput = document.getElementById('qty');
    const plusBtn = document.getElementById('plus-btn');
    const minusBtn = document.getElementById('minus-btn');

    if (plusBtn && minusBtn && qtyInput) {
      plusBtn.addEventListener('click', function() {
        const currentVal = parseInt(qtyInput.value) || 1;
        const maxStock = parseInt(qtyInput.getAttribute('max')) || Infinity;
        if (currentVal < maxStock) {
          qtyInput.value = currentVal + 1;
        }
      });

      minusBtn.addEventListener('click', function() {
        const currentVal = parseInt(qtyInput.value) || 1;
        const minVal = parseInt(qtyInput.getAttribute('min')) || 1;
        if (currentVal > minVal) {
          qtyInput.value = currentVal - 1;
        }
      });
    }
  });
</script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const dropzone = document.getElementById('dropzone');
    const fileInput = document.getElementById('customImageInput');
    const placeholder = document.getElementById('upload-placeholder');
    const preview = document.getElementById('upload-preview');
    const previewImg = document.getElementById('preview-img');
    const removeBtn = preview.querySelector('button');

    // 1. Trigger file selection kapag clinick ang dropzone
    if (dropzone && fileInput) {
        dropzone.addEventListener('click', function(e) {
            if (e.target !== fileInput && !e.target.closest('button')) {
                fileInput.click();
            }
        });
    }

    // 2. Imbes na 'onchange' sa HTML, dito natin ilagay ang listener (Iwas CSP error)
    if (fileInput) {
        fileInput.addEventListener('change', function() {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    placeholder.classList.add('hidden');
                    preview.classList.remove('hidden');
                };
                reader.readAsDataURL(this.files[0]);
            }
        });
    }

    // 3. Remove Button Logic
    if (removeBtn) {
        removeBtn.addEventListener('click', function(e) {
            e.stopPropagation(); // Stop dropzone from opening file selector
            fileInput.value = "";
            previewImg.src = "";
            placeholder.classList.remove('hidden');
            preview.classList.add('hidden');
        });
    }
});
</script>