<% layout('layouts/main') %>

<div class="mb-4">
  <a href="/customer/cart" class="text-primary hover:underline text-sm">
    <i class="fas fa-arrow-left mr-1"></i>Back to Cart
  </a>
</div>

<h1 class="text-3xl font-bold text-dark mb-6">
  <i class="fas fa-credit-card text-primary mr-2"></i>Checkout
</h1>

<form id="orderForm" action="/customer/place-order" method="POST" enctype="multipart/form-data">
  
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <div class="lg:col-span-2 space-y-6">
      
      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100">
        <h2 class="text-lg font-bold text-dark mb-4">
          <i class="fas fa-truck text-primary mr-2"></i>Shipping Information
        </h2>
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Shipping Address</label>
            <textarea name="shippingAddress" required rows="3" placeholder="Complete delivery address"
              class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition resize-none"><%= user && user.address ? user.address : '' %></textarea>
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contact Number</label>
            <div class="relative">
              <i class="fas fa-phone absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"></i>
              <input type="text" name="contactNumber" required placeholder="09123456789"
                value="<%= user && user.phoneNumber ? user.phoneNumber : '' %>"
                class="w-full pl-10 pr-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition" />
            </div>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100">
        <h2 class="text-lg font-bold text-dark mb-2">
          <i class="fas fa-upload text-primary mr-2"></i>Upload Supporting Files
        </h2>
        <p class="text-gray-500 text-sm mb-4">Upload any additional inspo photos or design references for this specific order.</p>

        <div class="border-2 border-dashed border-gray-300 rounded-lg p-8 text-center hover:border-primary transition cursor-pointer bg-gray-50 group" id="checkout-dropzone">
          <input type="file" name="supportingFiles" accept="image/*" multiple class="hidden" id="supportingFilesInput" onchange="previewFiles(this)" />
          <i class="fas fa-cloud-upload-alt text-gray-400 text-4xl mb-3 group-hover:text-primary transition"></i>
          <p class="text-gray-500">Click or drag files here</p>
          <p class="text-gray-400 text-xs mt-1">JPG, PNG, SVG — Multiple files allowed</p>
        </div>
        <div id="files-preview" class="flex flex-wrap gap-3 mt-4"></div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6 border border-gray-100">
        <h2 class="text-lg font-bold text-dark mb-4">
          <i class="fas fa-sticky-note text-primary mr-2"></i>Order Notes 
          <span class="text-gray-400 font-normal text-sm">(optional)</span>
        </h2>
        <textarea name="notes" rows="3" placeholder="Any special instructions for your order..."
          class="w-full px-4 py-2.5 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition resize-none"></textarea>
      </div>
    </div>

    <div>
      <div class="bg-white rounded-xl shadow-md p-6 sticky top-24 border border-blue-50">
        <h2 class="text-xl font-bold text-dark mb-4"><i class="fas fa-receipt mr-2"></i>Order Summary</h2>

        <div class="space-y-3 max-h-80 overflow-y-auto pr-2 custom-scrollbar">
          <% let total = 0; %>
          <% if (typeof cartItems !== 'undefined' && cartItems.length > 0) { %>
            <% cartItems.forEach(item => { total += item.totalPrice; %>
              <div class="flex gap-3 pb-3 border-b border-gray-100">
                <input type="hidden" name="itemIds[]" value="<%= item._id %>">
                
                <img src="<%= item.productId.imageUrl %>" class="w-14 h-14 rounded-lg object-cover flex-shrink-0 border" />
                <div class="flex-1 min-w-0">
                  <p class="font-medium text-sm text-dark truncate"><%= item.productId.name %></p>
                  <p class="text-xs text-gray-400">Qty: <%= item.quantity %></p>
                  <% if(item.selectedSize) { %>
                    <span class="text-[10px] bg-gray-100 px-1 rounded text-gray-600"><%= item.selectedSize %></span>
                  <% } %>
                </div>
                <span class="font-semibold text-sm text-primary whitespace-nowrap">&#8369;<%= item.totalPrice.toFixed(2) %></span>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-gray-400 text-center py-4 text-sm">No items selected.</p>
          <% } %>
        </div>

        <div class="mt-6 space-y-2">
            <div class="flex justify-between text-sm text-gray-500">
                <span>Subtotal</span>
                <span>&#8369;<%= total.toFixed(2) %></span>
            </div>
            <div class="flex justify-between text-sm text-gray-500">
                <span>Shipping</span>
                <span class="text-green-500 font-medium">FREE</span>
            </div>
            <hr class="my-2">
            <div class="flex justify-between text-lg font-bold text-dark">
              <span>Total</span>
              <span class="text-primary">&#8369;<%= total.toFixed(2) %></span>
            </div>
        </div>

        <button type="button" id="placeOrderBtn" 
          class="mt-6 w-full bg-primary hover:bg-purple-700 text-white font-bold py-3 rounded-xl transition shadow-lg shadow-purple-200 flex items-center justify-center gap-2 <%= (typeof cartItems === 'undefined' || cartItems.length === 0) ? 'opacity-50 cursor-not-allowed' : '' %>"
          <%= (typeof cartItems === 'undefined' || cartItems.length === 0) ? 'disabled' : '' %>>
          <i class="fas fa-check-circle"></i> Place Order
        </button>
        
        <p class="text-[10px] text-gray-400 text-center mt-3">
            By clicking "Place Order", you agree to our terms of service.
        </p>
      </div>
    </div>
  </div>
</form>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const orderBtn = document.getElementById('placeOrderBtn');
    const orderForm = document.getElementById('orderForm');
    const czDropzone = document.getElementById('checkout-dropzone');
    const czInput = document.getElementById('supportingFilesInput');

    // --- 1. Dropzone Logic ---
    if (czDropzone && czInput) {
        czDropzone.addEventListener('click', () => czInput.click());
        
        czDropzone.addEventListener('dragover', e => { 
            e.preventDefault(); 
            czDropzone.classList.replace('bg-gray-50', 'bg-blue-50');
            czDropzone.classList.add('border-primary'); 
        });

        czDropzone.addEventListener('dragleave', () => {
            czDropzone.classList.replace('bg-blue-50', 'bg-gray-50');
            czDropzone.classList.remove('border-primary');
        });

        czDropzone.addEventListener('drop', e => {
            e.preventDefault(); 
            czDropzone.classList.replace('bg-blue-50', 'bg-gray-50');
            czDropzone.classList.remove('border-primary');
            czInput.files = e.dataTransfer.files; 
            previewFiles(czInput);
        });
    }

    // --- 2. Place Order Logic ---
    if (orderBtn) {
        orderBtn.addEventListener('click', async () => {
            const address = document.querySelector('textarea[name="shippingAddress"]').value.trim();
            const phone = document.querySelector('input[name="contactNumber"]').value.trim();

            if (!address || !phone) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Missing Details',
                    text: 'Please provide both your shipping address and contact number.',
                    confirmButtonColor: '#7C3AED' // Matches Primary
                });
                return;
            }

            const result = await Swal.fire({
                title: 'Confirm Purchase?',
                text: "Your order will be sent to our team for processing.",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#7C3AED',
                cancelButtonColor: '#9CA3AF',
                confirmButtonText: 'Yes, Place Order',
                cancelButtonText: 'Review Cart'
            });

            if (result.isConfirmed) {
                Swal.fire({
                    title: 'Processing Order',
                    text: 'Uploading files and securing your order...',
                    allowOutsideClick: false,
                    didOpen: () => {
                        Swal.showLoading();
                    }
                });
                orderForm.submit();
            }
        });
    }
});

// --- 3. Preview Logic ---
function previewFiles(input) {
    const container = document.getElementById('files-preview');
    container.innerHTML = '';

    if (input.files) {
        Array.from(input.files).forEach((file, i) => {
            const reader = new FileReader();
            reader.onload = e => {
                const div = document.createElement('div');
                div.className = "relative group animate-fade-in";
                div.innerHTML = `
                    <img src="${e.target.result}" class="w-20 h-20 rounded-lg object-cover border-2 border-gray-200 shadow-sm" />
                    <span class="absolute -top-2 -right-2 bg-primary text-white text-[10px] w-5 h-5 rounded-full flex items-center justify-center font-bold shadow-md border border-white">
                        ${i + 1}
                    </span>
                `;
                container.appendChild(div);
            };
            reader.readAsDataURL(file);
        });
    }
}
</script>

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: #f1f1f1; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #d1d5db; border-radius: 10px; }
    .animate-fade-in { animation: fadeIn 0.3s ease-in; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
</style>