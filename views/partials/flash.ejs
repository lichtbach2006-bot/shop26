<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-2">
  <% if (error) { %>
    <div class="flash-msg bg-red-50 border-l-4 border-red-500 text-red-700 px-4 py-3 rounded-r-lg flex items-center justify-between mb-2" role="alert">
      <div class="flex items-center gap-2">
        <i class="fas fa-exclamation-circle"></i>
        <span><%= error %></span>
      </div>
      <button onclick="this.parentElement.remove()" class="text-red-400 hover:text-red-600"><i class="fas fa-times"></i></button>
    </div>
  <% } %>

  <% if (success) { %>
    <div class="flash-msg bg-green-50 border-l-4 border-green-500 text-green-700 px-4 py-3 rounded-r-lg flex items-center justify-between mb-2" role="alert">
      <div class="flex items-center gap-2">
        <i class="fas fa-check-circle"></i>
        <span><%= success %></span>
      </div>
      <button onclick="this.parentElement.remove()" class="text-green-400 hover:text-green-600"><i class="fas fa-times"></i></button>
    </div>
  <% } %>

  <% if (warning) { %>
    <div class="flash-msg bg-yellow-50 border-l-4 border-yellow-500 text-yellow-700 px-4 py-3 rounded-r-lg flex items-center justify-between mb-2" role="alert">
      <div class="flex items-center gap-2">
        <i class="fas fa-exclamation-triangle"></i>
        <span><%= warning %></span>
      </div>
      <button onclick="this.parentElement.remove()" class="text-yellow-400 hover:text-yellow-600"><i class="fas fa-times"></i></button>
    </div>
  <% } %>

  <% if (denied) { %>
    <div class="flash-msg bg-orange-50 border-l-4 border-orange-500 text-orange-700 px-4 py-3 rounded-r-lg flex items-center justify-between mb-2" role="alert">
      <div class="flex items-center gap-2">
        <i class="fas fa-ban"></i>
        <span><%= denied %></span>
      </div>
      <button onclick="this.parentElement.remove()" class="text-orange-400 hover:text-orange-600"><i class="fas fa-times"></i></button>
    </div>
  <% } %>

  <% if (message) { %>
    <div class="flash-msg bg-blue-50 border-l-4 border-blue-500 text-blue-700 px-4 py-3 rounded-r-lg flex items-center justify-between mb-2" role="alert">
      <div class="flex items-center gap-2">
        <i class="fas fa-info-circle"></i>
        <span><%= message %></span>
      </div>
      <button onclick="this.parentElement.remove()" class="text-blue-400 hover:text-blue-600"><i class="fas fa-times"></i></button>
    </div>
  <% } %>

  <% if (typeof messageSuccess !== 'undefined' && messageSuccess && messageSuccess.length > 0) { %>
    <% messageSuccess.forEach(msg => { %>
      <div class="flash-msg bg-green-50 border-l-4 border-green-500 text-green-700 px-4 py-3 rounded-r-lg flex items-center justify-between mb-2" role="alert">
        <div class="flex items-center gap-2">
          <i class="fas fa-check-circle"></i>
          <span><%= msg %></span>
        </div>
        <button onclick="this.parentElement.remove()" class="text-green-400 hover:text-green-600"><i class="fas fa-times"></i></button>
      </div>
    <% }) %>
  <% } %>
</div>
