<% layout('layouts/main') %>

<div class="mb-8">
  <h1 class="text-3xl font-bold text-dark flex items-center gap-2">
    <i class="fas fa-user-shield text-primary"></i>
    Admin Profile
  </h1>
  <p class="text-gray-500 text-sm mt-1">Manage your account information and security settings.</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
  
  <aside class="lg:col-span-1">
    <div class="bg-white rounded-2xl shadow-md p-8 text-center border border-gray-100">
      <div class="relative inline-block">
        <% if (typeof profile !== 'undefined' && profile.profileImage) { %>
          <img src="<%= profile.profileImage %>" class="w-32 h-32 rounded-full object-cover border-4 border-primary/10 shadow-sm" />
        <% } else { %>
          <div class="w-32 h-32 rounded-full bg-primary/5 flex items-center justify-center border-4 border-primary/10">
            <i class="fas fa-user-shield text-primary text-5xl"></i>
          </div>
        <% } %>
        
        <form action="/admin/profile/photo" method="POST" enctype="multipart/form-data" id="photoForm">
          <label class="absolute bottom-0 right-0 bg-white p-2 rounded-full shadow-lg border border-gray-100 cursor-pointer hover:text-primary transition">
            <i class="fas fa-camera"></i>
            <input type="file" name="profileImage" accept="image/*" class="hidden" onchange="document.getElementById('photoForm').submit()" />
          </label>
        </form>
      </div>

      <div class="mt-5">
        <h2 class="font-bold text-2xl text-dark">
          <%= typeof profile !== 'undefined' ? profile.firstName + ' ' + profile.lastName : 'Admin User' %>
        </h2>
        <p class="text-gray-500 text-sm font-medium"><%= typeof profile !== 'undefined' ? profile.email : 'admin@email.com' %></p>
        <div class="mt-3">
          <span class="px-4 py-1.5 rounded-full text-xs font-bold bg-red-50 text-red-600 tracking-wider uppercase">
            System Administrator
          </span>
        </div>
      </div>
    </div>
  </aside>

  <main class="lg:col-span-2 space-y-8">
    
    <section class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100">
      <div class="p-6 border-b border-gray-50 bg-gray-50/50">
        <h2 class="text-lg font-bold text-dark flex items-center gap-2">
          <i class="fas fa-edit text-primary"></i> Personal Information
        </h2>
      </div>
      
      <div class="p-6">
        <form action="/admin/profile/update" method="POST" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-1.5">First Name</label>
              <input type="text" name="firstName" required pattern="^[A-Za-z\s]+$" 
                     title="Letters only, please."
                     value="<%= typeof profile !== 'undefined' ? profile.firstName : '' %>"
                     class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-1.5">Last Name</label>
              <input type="text" name="lastName" required pattern="^[A-Za-z\s]+$" 
                     title="Letters only, please."
                     value="<%= typeof profile !== 'undefined' ? profile.lastName : '' %>"
                     class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
            </div>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-1.5">Phone Number</label>
              <input type="tel" name="phoneNumber" required pattern="[0-9]{11}" 
                     placeholder="09171234567"
                     value="<%= typeof profile !== 'undefined' ? profile.phoneNumber : '' %>"
                     class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-1.5">Email (Read Only)</label>
              <input type="email" disabled value="<%= typeof profile !== 'undefined' ? profile.email : '' %>"
                     class="w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl text-gray-400 cursor-not-allowed" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-gray-600 mb-1.5">Complete Address</label>
            <textarea name="address" required rows="3"
                      class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all"
            ><%= typeof profile !== 'undefined' ? profile.address : '' %></textarea>
          </div>

          <div class="flex justify-end pt-4">
            <button type="submit" class="bg-primary hover:bg-primary-dark text-white font-bold py-3 px-8 rounded-xl transition-all shadow-md active:scale-95">
              Update Profile
            </button>
          </div>
        </form>
      </div>
    </section>

    <section class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100">
      <div class="p-6 border-b border-gray-50 bg-gray-50/50">
        <h2 class="text-lg font-bold text-dark flex items-center gap-2">
          <i class="fas fa-key text-primary"></i> Security & Password
        </h2>
      </div>
      
      <div class="p-6">
        <form action="/admin/profile/password" method="POST" class="space-y-5">
          <div>
            <label class="block text-sm font-semibold text-gray-600 mb-1.5">Current Password</label>
            <input type="password" name="currentPassword" required
                   class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-1.5">New Password</label>
              <input type="password" name="newPassword" required minlength="6"
                     class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-600 mb-1.5">Confirm New Password</label>
              <input type="password" name="confirmNewPassword" required minlength="6"
                     class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all" />
            </div>
          </div>

          <div class="flex justify-end pt-4">
            <button type="submit" class="bg-gray-800 hover:bg-gray-900 text-white font-bold py-3 px-8 rounded-xl transition-all shadow-md active:scale-95">
              Change Password
            </button>
          </div>
        </form>
      </div>
    </section>

  </main>
</div>