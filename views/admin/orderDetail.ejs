<% layout('layouts/main') %>

<div class="mb-4">
  <a href="/admin/orders" class="text-primary hover:underline text-sm"><i class="fas fa-arrow-left mr-1"></i>Back to Orders</a>
</div>

<div class="bg-white rounded-xl shadow-md p-6 mb-6">
  <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
    <div>
      <h1 class="text-2xl font-bold text-dark">Order #<%= order.orderNumber %></h1>
      <p class="text-gray-500 text-sm mt-1"><%= new Date(order.createdAt).toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></p>
      <% if (order.userId) { %>
        <p class="text-gray-500 text-sm mt-1"><i class="fas fa-user mr-1"></i><%= order.userId.firstName %> <%= order.userId.lastName %> (<%= order.userId.email %>)</p>
      <% } %>
    </div>
    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-3">
      <span class="text-primary font-bold text-2xl">&#8369;<%= order.totalAmount.toFixed(2) %></span>
      <form action="/admin/orders/<%= order._id %>/status" method="POST" class="flex items-center gap-2">
        <select name="status" class="px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary outline-none text-sm">
          <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
          <option value="processing" <%= order.status === 'processing' ? 'selected' : '' %>>Processing</option>
          <option value="ready" <%= order.status === 'ready' ? 'selected' : '' %>>Ready</option>
          <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
          <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
          <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
        </select>
        <button type="submit" class="bg-primary hover:bg-purple-700 text-white px-4 py-2 rounded-lg transition text-sm font-medium">
          <i class="fas fa-sync-alt mr-1"></i>Update
        </button>
      </form>
    </div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <div class="bg-white rounded-xl shadow-md p-6">
    <h2 class="text-lg font-bold text-dark mb-4"><i class="fas fa-list text-primary mr-2"></i>Order Items</h2>
    <% if (typeof orderItems !== 'undefined' && orderItems.length > 0) { %>
      <div class="space-y-4">
        <% orderItems.forEach(item => { %>
          <div class="flex gap-4 pb-4 border-b border-gray-100 last:border-0">
            <img src="<%= item.productId.imageUrl %>" class="w-16 h-16 rounded-lg object-cover flex-shrink-0" />
            <div class="flex-1">
              <h3 class="font-semibold text-dark text-sm"><%= item.productId.name %></h3>
              <div class="text-xs text-gray-500 mt-1 space-y-0.5">
                <% if (item.selectedSize) { %><p>Size: <%= item.selectedSize %></p><% } %>
                <% if (item.selectedColor) { %><p>Color: <%= item.selectedColor %></p><% } %>
                <% if (item.customText) { %><p>Text: "<%= item.customText %>"</p><% } %>
                <% if (item.customImageUrl) { %><p>Design: <a href="<%= item.customImageUrl %>" target="_blank" class="text-primary hover:underline">View</a></p><% } %>
                <p>Qty: <%= item.quantity %> x &#8369;<%= item.itemPrice.toFixed(2) %></p>
              </div>
            </div>
            <span class="font-bold text-primary text-sm">&#8369;<%= item.subtotal.toFixed(2) %></span>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-gray-400 text-sm">No items found.</p>
    <% } %>
  </div>

  <div class="space-y-6">
    <div class="bg-white rounded-xl shadow-md p-6">
      <h2 class="text-lg font-bold text-dark mb-4"><i class="fas fa-map-marker-alt text-primary mr-2"></i>Shipping Info</h2>
      <div class="text-sm space-y-2">
        <p><span class="text-gray-500">Address:</span> <span class="font-medium"><%= order.shippingAddress %></span></p>
        <p><span class="text-gray-500">Contact:</span> <span class="font-medium"><%= order.contactNumber %></span></p>
      </div>
    </div>

<div class="bg-white rounded-xl shadow-md p-6">
  <h2 class="text-lg font-bold text-dark mb-4">
    <i class="fas fa-truck text-primary mr-2"></i>Shipping Management
  </h2>
  
  <% if (typeof shipping !== 'undefined' && shipping) { %>
    <div class="text-sm space-y-2 mb-4 p-4 bg-purple-50 rounded-lg border border-purple-100">
      <p class="flex justify-between items-center">
        <span class="text-gray-500">Estimated Delivery:</span> 
        <span class="font-bold text-primary text-base">
          <%= new Date(shipping.estimatedDelivery).toLocaleDateString('en-PH', { year: 'numeric', month: 'long', day: 'numeric' }) %>
        </span>
      </p>
      <p class="flex justify-between items-center">
        <span class="text-gray-500">Current Status:</span> 
        <span class="font-semibold capitalize px-2 py-1 bg-white rounded border text-indigo-600">
          <%= shipping.shippingStatus %>
        </span>
      </p>
    </div>

    <form action="/admin/orders/<%= order._id %>/shipping/<%= shipping._id %>/update" method="POST" class="space-y-3">
      <label class="block text-xs font-medium text-gray-700">Update Shipping Status</label>
      <select name="shippingStatus" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary outline-none text-sm">
        <option value="preparing" <%= shipping.shippingStatus === 'preparing' ? 'selected' : '' %>>Preparing</option>
        <option value="shipped" <%= shipping.shippingStatus === 'shipped' ? 'selected' : '' %>>Shipped</option>
        <option value="in_transit" <%= shipping.shippingStatus === 'in_transit' ? 'selected' : '' %>>In Transit</option>
        <option value="delivered" <%= shipping.shippingStatus === 'delivered' ? 'selected' : '' %>>Delivered</option>
      </select>
      <button type="submit" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg transition text-sm font-medium shadow-sm">
        <i class="fas fa-sync-alt mr-1"></i>Update Status
      </button>
    </form>

  <% } else { %>
    <form action="/admin/orders/<%= order._id %>/shipping" method="POST" class="space-y-4">
      <div class="bg-gray-50 p-4 rounded-lg border border-dashed border-gray-300">
        <label class="block text-sm font-semibold text-gray-700 mb-2">
          <i class="far fa-calendar-alt mr-1"></i>Set Estimated Delivery Date
        </label>
        <input type="date" name="estimatedDelivery" required
          class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary outline-none text-sm shadow-sm" />
        <p class="text-[10px] text-gray-400 mt-2">Note: This will notify the customer regarding their delivery schedule.</p>
      </div>

      <button type="submit" class="w-full bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded-lg transition text-sm font-medium shadow-md">
        <i class="fas fa-check-circle mr-1"></i>Confirm Delivery Date
      </button>
    </form>
  <% } %>
</div>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
 <div class="bg-white rounded-xl shadow-md p-6">
  <h2 class="text-lg font-bold text-dark mb-4">
    <i class="fas fa-images text-primary mr-2"></i>Customer Uploaded Designs
  </h2>
  
  <% 
    // Kunin lahat ng items na may customImageUrl mula sa orderItems
    let customItems = [];
    if (typeof orderItems !== 'undefined' && orderItems.length > 0) {
      customItems = orderItems.filter(item => item.customImageUrl);
    }
  %>

  <% if (customItems.length > 0) { %>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      <% customItems.forEach(item => { %>
        <div class="flex flex-col gap-2">
          <a href="<%= item.customImageUrl %>" target="_blank" class="relative group block">
            <img src="<%= item.customImageUrl %>" 
                 alt="Customer Design" 
                 class="w-full h-32 object-cover rounded-lg border-2 border-gray-200 group-hover:border-primary transition" />
            
            <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 rounded-lg transition flex items-center justify-center">
              <div class="text-center">
                <i class="fas fa-search-plus text-white text-xl block mb-1"></i>
                <span class="text-white text-[10px] font-medium">VIEW FULL</span>
              </div>
            </div>
          </a>
          
          <div class="bg-gray-50 p-2 rounded-md border border-gray-100">
            <p class="text-[10px] font-bold text-gray-700 truncate">
              <%= item.productId ? item.productId.name : 'Unknown Product' %>
            </p>
            <% if (item.customText) { %>
              <p class="text-[9px] text-primary italic truncate">Text: "<%= item.customText %>"</p>
            <% } %>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="text-center py-6">
      <i class="fas fa-photo-video text-gray-200 text-4xl mb-2"></i>
      <p class="text-gray-400 text-sm italic">No custom designs uploaded for this order.</p>
    </div>
  <% } %>
</div>

  <div class="bg-white rounded-xl shadow-md p-6">
    <h2 class="text-lg font-bold text-dark mb-4"><i class="fas fa-sticky-note text-primary mr-2"></i>Order Notes</h2>
    <% if (order.notes) { %>
      <p class="text-gray-600 leading-relaxed"><%= order.notes %></p>
    <% } else { %>
      <p class="text-gray-400 text-sm italic">No notes provided.</p>
    <% } %>
  </div>
</div>

<script>
  const courierInput = document.getElementById('courierInput');

courierInput.addEventListener('input', function(e) {
  // Pinapalitan ang lahat ng numero (0-9) ng "empty string"
  this.value = this.value.replace(/[0-9]/g, '');
});
</script>